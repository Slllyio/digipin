# Screenshots (dev artifacts)
*.png

# Playwright MCP artifacts
.playwright-mcp/

# Training data (large files, not for git)
training-data/digipin-*.json
training-data/disha-qlora-output/

# OS files
desktop.ini
Thumbs.db
.DS_Store

# Editor
.vscode/
*.swp
*.swo

# Node
node_modules/
package-lock.json

# Test coverage reports (generated by `vitest run --coverage`)
coverage/

# Video output (large binary files)
video-output/

# Python cache
__pycache__/
*.pyc

# Data files (large, generated by pipeline) — everything under data/
# is ignored EXCEPT the small frontend-consumed realtime snapshots.
data/*
!data/realtime/
data/realtime/*
!data/realtime/.gitignore
!data/realtime/README.md
!data/realtime/*/
data/realtime/*/*
!data/realtime/*/latest.json
!data/realtime/*/README.md
# Precomputed score tiles are committed and served by Pages (like realtime/).
!data/scores/
data/scores/*
!data/scores/coverage.json
!data/scores/*/
data/scores/*/*
!data/scores/*/*.json
!data/scores/*/*.pmtiles

# SUMO simulation data (large XML files)
guna-twin-city/traffic-analysis/sumo/*.xml

# Analysis output (generated maps/data)
guna-twin-city/analysis/output/

# Large binary files
*.pptx

# Experimental / WIP
building-blocks/
iD/
cesium-demo.html

# Personal Claude Code permission allowlist — local-only
.claude/settings.local.json

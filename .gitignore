# Screenshots (dev artifacts)
*.png

# Playwright MCP artifacts
.playwright-mcp/

# Training data (large files, not for git)
training-data/digipin-*.json
training-data/disha-qlora-output/

# OS files
desktop.ini
Thumbs.db
.DS_Store

# Editor
.vscode/
*.swp
*.swo

# Node
node_modules/
package-lock.json

# Video output (large binary files)
video-output/

# Python cache
__pycache__/
*.pyc

# Data files (large, generated by pipeline) — everything under data/
# is ignored EXCEPT the small frontend-consumed realtime snapshots.
data/*
!data/realtime/
data/realtime/*
!data/realtime/.gitignore
!data/realtime/README.md
!data/realtime/*/
data/realtime/*/*
!data/realtime/*/latest.json
!data/realtime/*/README.md

# Bharatlas mirror — keep the index files in git, leave the GB of
# PMTiles/parquet locally only (run pipeline/bharatlas/fetch_all.py).
!data/bharatlas/
data/bharatlas/*
!data/bharatlas/catalog.json
!data/bharatlas/MANIFEST.json
!data/bharatlas/README.md

# GEE-derived COGs for the Indore pilot — small enough (~3 MB total)
# to commit. The growth/heat overlays require these to render. Regenerate
# with `python pipeline/extract_indore_cogs.py`. India-wide versions
# (DIGIPIN_REGION=india_full) stay gitignored.
!data/growth/
!data/heat/
data/growth/*
data/heat/*
!data/growth/*_indore_pilot.tif
!data/heat/*_indore_pilot.tif

# SUMO simulation data (large XML files)
guna-twin-city/traffic-analysis/sumo/*.xml

# Analysis output (generated maps/data)
guna-twin-city/analysis/output/

# Large binary files
*.pptx

# Experimental / WIP
building-blocks/
iD/
cesium-demo.html

# Personal Claude Code permission allowlist — local-only
.claude/settings.local.json

# Screenshots (dev artifacts)
*.png
# …except committed product assets (landing hero, etc.)
!assets/
!assets/**

# Playwright MCP artifacts
.playwright-mcp/

# Training data (large files, not for git)
training-data/digipin-*.json
training-data/disha-qlora-output/

# OS files
desktop.ini
Thumbs.db
.DS_Store

# Editor
.vscode/
*.swp
*.swo

# Node
node_modules/
package-lock.json

# Test coverage reports (generated by `vitest run --coverage`)
coverage/

# Video output (large binary files)
video-output/

# Python cache
__pycache__/
*.pyc

# Data files (large, generated by pipeline) — everything under data/
# is ignored EXCEPT the small frontend-consumed realtime snapshots.
data/*
!data/realtime/
data/realtime/*
!data/realtime/.gitignore
!data/realtime/README.md
!data/realtime/*/
data/realtime/*/*
!data/realtime/*/latest.json
# Baked per-building heights (Open Buildings 2.5D) — shipped so the deployed
# static site can serve them; regenerate with scripts/build_building_heights.py.
!data/heights/
!data/heights/*
# Pipeline rasters/vectors regenerated for the static deploy so overlays work.
!data/heat/
!data/heat/*
!data/growth/
!data/growth/*
!data/vectors/
!data/vectors/*
!data/realtime/*/README.md
# Precomputed score tiles are committed and served by Pages (like realtime/).
!data/scores/
data/scores/*
!data/scores/coverage.json
!data/scores/*/
data/scores/*/*
!data/scores/*/*.json
!data/scores/*/*.pmtiles
# Precomputed traffic (structural congestion) artifacts — browser-consumed.
!data/traffic/
data/traffic/*
!data/traffic/*/
data/traffic/*/*
!data/traffic/*/*.json
!data/traffic/*/*.geojson
# Precomputed law-and-order mobility (access-resilience) artifacts — browser-consumed.
!data/safety/
data/safety/*
!data/safety/*/
data/safety/*/*
!data/safety/*/*.json
!data/safety/*/*.geojson
# Bundled utilities/infrastructure regional reference — browser-consumed.
!data/utilities/
data/utilities/*
!data/utilities/*/
data/utilities/*/*
!data/utilities/*/*.json

# OSM vector layers (Digital-Twin) — small browser-consumed GeoJSON only.
# Large vector PMTiles stay ignored (served from S3/Overture, not Pages).
!data/vectors/
data/vectors/*
!data/vectors/*.geojson

# SUMO simulation data (large XML files)
guna-twin-city/traffic-analysis/sumo/*.xml

# Analysis output: ignore heavy generated maps/rasters, keep small summary JSONs
guna-twin-city/analysis/output/*
!guna-twin-city/analysis/output/flood_cn_guna.json
!guna-twin-city/analysis/output/flood_buildings_guna.geojson
!guna-twin-city/analysis/output/flood_risk_cells_guna.geojson

# Large binary files
*.pptx

# SUMO simulation data (large XML files)
guna-twin-city/traffic-analysis/sumo/*.xml

# Analysis output: ignore heavy generated maps/rasters, keep small summary JSONs
guna-twin-city/analysis/output/*
!guna-twin-city/analysis/output/flood_cn_guna.json
!guna-twin-city/analysis/output/flood_buildings_guna.geojson
!guna-twin-city/analysis/output/flood_risk_cells_guna.geojson

# Large binary files
*.pptx

# Experimental / WIP
building-blocks/
iD/
cesium-demo.html

# Local git worktrees (agent isolation) — never commit
DigiPin.worktrees/

# Personal Claude Code permission allowlist — local-only
.claude/settings.local.json

# Generated promo video + frames (build via extras/promo-stills.mjs + build-promo.py)
extras/out/

# ===== Guna twin: ignore heavy local source data, keep generated map artifacts =====
guna-twin-city/data/*
!guna-twin-city/data/ai_outputs/
guna-twin-city/data/ai_outputs/*
!guna-twin-city/data/ai_outputs/*.geojson
!guna-twin-city/data/scores/
guna-twin-city/data/scores/*
!guna-twin-city/data/scores/*.json
!guna-twin-city/data/scores/*/
!guna-twin-city/data/scores/*/*.json
!guna-twin-city/data/scores/*/*.pmtiles
# Browser-served raster overlays (MODIS LST heat + CA-ML growth COGs).
!guna-twin-city/data/heat/
!guna-twin-city/data/heat/*.tif
!guna-twin-city/data/growth/
!guna-twin-city/data/growth/*.tif
# Browser-served Digital-Twin vector layers (DT-layers menu + strategic-twin
# Ward Dashboard). Only the frontend-referenced files — the heavier pipeline
# intermediates (roads_centrality, service_gaps, settlement_index, the source
# google_open_buildings geojson, etc.) stay ignored.
# Browser-served Traffic LOS + Law-&-Order Mobility datasets (per region).
!guna-twin-city/data/traffic/
!guna-twin-city/data/traffic/*/
!guna-twin-city/data/traffic/*/*.json
!guna-twin-city/data/traffic/*/*.geojson
